<UserControl x:Class="vamara_demo_browser.Controls.Shell32.BreadcrumbBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:vamara_demo_browser.Controls.Shell32" 
             xmlns:models="using:vamara_demo_browser.Models" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             d:DataContext="{d:DesignInstance Type=models:HeaderViewModel}">

    <Grid Background="{ThemeResource LayerFillColorDefaultBrush}" Height="48">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="16"/>
        </Grid.ColumnDefinitions>

        <StackPanel x:Name="BreadcrumbPanel" Orientation="Horizontal">

        </StackPanel>
    </Grid>
</UserControl>
    