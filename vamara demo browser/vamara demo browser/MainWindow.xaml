<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="vamara_demo_browser.MainWindow"
    xmlns:local="using:vamara_demo_browser"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    mc:Ignorable="d"
    Title="vamara. interop with pleasure. demo browser beta build">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <NavigationView x:Name="RootNavigationView" >
            <NavigationView.MenuItems>
                <NavigationViewItem Icon="World"                  Content="Home"                Tag="Wellcome Home"  />
                <NavigationViewItem Icon="Save"                   Content="Windows Forms"       Tag="Windows Forms Controls"  />
                <NavigationViewItem Icon="ProtectedDocument"      Content="Docs"                Tag="Documentation"  />
                <NavigationViewItem Icon="Calendar"               Content="History"             Tag="History"  />
                <NavigationViewItem Icon="Bullets"                Content="Bulb"                Tag="suggest a feature..." />
                <NavigationViewItem Icon="Download"               Content="Packages on NuGet"   Tag="Download packages from NGet" />
                <NavigationViewItem Icon="Admin"                  Content="Copilot"             Tag="Use Copilot" />
                <NavigationViewItem Icon="GlobalNavigationButton" Content="GitHub Client"       Tag="Use GitHub client" />
                <!-- Friday, 13th of March 2026 -->
                <NavigationViewItem Icon="Upload"                 Content="Bulb"                Tag="submit a bug..." />
                <NavigationViewItem Icon="Upload"                 Content="Bulb"                Tag="submit a bug..." />
            </NavigationView.MenuItems>
            <!-- App app (use drag and drop, or add manually, or grab folder of open explorer window)"  -->
            <!-- <NavigationCacheMode>Enabled</NavigationCacheMode>-->
            <!-- <NavigationCacheMode="Enabled"/>-->
            <Frame x:Name="navigationViewContentFrame">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                    <!-- HEADER -->
                    <Border Grid.Row="0" Background="{ThemeResource SystemControlAcrylicWindowBrush}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Vanara – The Friendly Interop Beast" FontSize="28" FontWeight="Bold"/>
                            <TextBlock Text="Bringing WinUI 3 and Win32 together since forever." Opacity="0.7"/>
                        </StackPanel>
                    </Border>
                    <!-- TABVIEW -->
                    <TabView x:Name="MainTabs" Grid.Row="1" IsAddTabButtonVisible="False">
                        <TabViewItem Header="Overview"/>
                        <TabViewItem Header="Packages"/>
                        <TabViewItem Header="Interop"/>
                        <TabViewItem Header="Shell"/>
                        <TabViewItem Header="Windowing"/>
                        <TabViewItem Header="Composition"/>
                    </TabView>

                    <!-- RIBBON (optional) -->
                    <CommandBar x:Name="RibbonBar" Grid.Row="2" DefaultLabelPosition="Right">
                        <AppBarButton Icon="Refresh" Label="Reload"/>
                        <AppBarButton Icon="Copy" Label="Copy Code"/>
                        <AppBarButton Icon="Help" Label="Docs"/>
                    </CommandBar>

                    <!-- CONTENT -->
                    <Frame x:Name="ContentFrame" Grid.Row="3" >
                    </Frame>
                </Grid>

