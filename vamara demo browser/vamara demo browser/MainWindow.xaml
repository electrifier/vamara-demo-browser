<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="vamara_demo_browser.MainWindow"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="using:vamara_demo_browser"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        mc:Ignorable="d"
        Title="vamara. interop with pleasure. demo browser beta build">
    <!-- ExtendsContentIntoTitleBar="True" -->
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>
    <Grid>
        <NavigationView x:Name="RootNavigationView" 
                        AlwaysShowHeader="False"
                        ExpandedModeThresholdWidth="256"
                        Header="Vanara Header"
                        IsBackButtonVisible="Auto"
                        IsBackEnabled="True"
                        IsSettingsVisible="True"
                        PaneDisplayMode="Left"
                        PaneTitle="Vana"
                        SelectionChanged="NavigationView_SelectionChanged" 
                        SelectionFollowsFocus="Disabled">
            <NavigationView.HeaderTemplate>
                <DataTemplate>
                    <!--<TextBlock Margin="12,0" Text="Vanara" FontSize="28" FontWeight="SemiBold" />
                    <HyperlinkButton Content="Microsoft home page" NavigateUri="https://github.com/tajbender/WinClassicSamplesCS" />-->
                    <!-- todo: Tapped="OnHeaderTapped" -->
                </DataTemplate>
            </NavigationView.HeaderTemplate>
            <NavigationView.MenuItems>
                <TextBlock Margin="12,0" Text="Vanara" FontSize="28" FontWeight="SemiBold" />
                <HyperlinkButton Content="Vanara on gitHub" NavigateUri="https://github.com/tajbender/WinClassicSamplesCS" />
                <NavigationViewItem Icon="Document" Content="Docs" Tag="Documents" />
                <NavigationViewItem Icon="Calendar" Content="History" Tag="History"  />
                <NavigationViewItemSeparator />
                <NavigationViewItem Icon="Download" Content="Vanara on GitHub..." Tag="Browse to github.com/Vanara" /><!-- https://github.com/dahall/Vanara -->
                <NavigationViewItem Icon="Download" IsEnabled="False" Content="Download NuGet Packages..." Tag="Browse to GitHub..."/>
                <NavigationViewItem Icon="Microphone" IsEnabled="False" Content="GitHub Client" Tag="Use GitHub client" />
                <!-- TODO: Where's :octocat ? -->
            </NavigationView.MenuItems>
            <!-- App app (use drag and drop, or add manually, or grab folder of open explorer window)"  -->
            <!-- <NavigationCacheMode="Enabled"/> -->
            <Frame x:Name="RootNavigationViewContentFrame">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                    <!-- HEADER -->
                    <Border Grid.Row="1" Background="{ThemeResource SystemControlAcrylicWindowBrush}" Padding="16">
                        <StackPanel>
                            <Image Width="96" Source="/Assets/Vanara64x64.png" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                            <!--<Image Height="256" Source="/Assets/.a.i. generated/Copilot/Copilot_20260315_191519.png" Visibility="Collapsed"/>
                            <TextBlock Text="Vanara – The Friendly Interop Beast" FontSize="28" FontWeight="Bold"/>
                            <TextBlock Text="Bringing WinUI 3 and Win32 together since forever." Opacity="0.7"/>-->
                        </StackPanel>
                    </Border>
                    <!-- TABVIEW -->
                    <TabView x:Name="MainTabs" Grid.Row="2" IsAddTabButtonVisible="False" Visibility="Collapsed">
                        <!--<TabViewItem Header="Overview"/>
                            <TabViewItem Header="Packages"/>
                            <TabViewItem Header="Interop"/>
                            <TabViewItem Header="Shell"/>
                            <TabViewItem Header="Windowing"/>
                            <TabViewItem Header="Composition"/>-->
                    </TabView>
                    <!-- RIBBON (optional) -->
                    <CommandBar x:Name="RibbonBar" Grid.Row="3" DefaultLabelPosition="Right">
                        <AppBarButton Icon="Refresh" Label="Reload"/>
                        <AppBarButton Icon="Copy" Label="Copy Code"/>
                        <AppBarButton Icon="Help" Label="Docs"/>
                    </CommandBar>


                    <!-- CONTENT -->
                    <Frame x:Name="ContentFrame" Grid.Row="4" >
                        <!--<Image Source="Assets/octocat.png" Width="64" Height="64"/>
                        <Image Source="ms-appx:///Assets/octocat.svg"/>-->
                    </Frame>
                </Grid>
            </Frame>
        </NavigationView>
    </Grid>
</Window>

