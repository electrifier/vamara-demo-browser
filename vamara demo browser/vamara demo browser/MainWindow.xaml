<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="vamara_demo_browser.MainWindow"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="using:vamara_demo_browser"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        mc:Ignorable="d"
        Title="vamara. interop with pleasure. demo browser beta build">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>
    <Grid>
        <NavigationView x:Name="RootNavigationView" AlwaysShowHeader="True" ExpandedModeThresholdWidth="320" Header="Vanara Header" IsBackButtonVisible="Auto" IsBackEnabled="True" IsSettingsVisible="True" IsTabStop="False" PaneDisplayMode="Left" PaneTitle="Vana" SelectionChanged="NavigationView_SelectionChanged" SelectionFollowsFocus="Disabled">
            <NavigationView.HeaderTemplate>
                <DataTemplate>
                    <TextBlock Text="Vana-ra" FontSize="28" FontWeight="SemiBold" Margin="12,0"/>
                    <!-- todo: Tapped="OnHeaderTapped" -->
                </DataTemplate>
            </NavigationView.HeaderTemplate>
            <NavigationView.MenuItems>
                <NavigationViewItem Icon="Document" Content="Docs" Tag="Documents"/>
                <NavigationViewItem Icon="Calendar" Content="History" Tag="History"  />
                <NavigationViewItemSeparator/>
                <NavigationViewItem Icon="Download" Content="Download Packages from NuGet" Tag="Download from NuGet" />
                <!-- TODO: Where's :octocat ? -->
                <NavigationViewItem Icon="GlobalNavigationButton" Content="GitHub Client" Tag="Use GitHub client" />
            </NavigationView.MenuItems>
            <!-- App app (use drag and drop, or add manually, or grab folder of open explorer window)"  -->
            <!-- <NavigationCacheMode="Enabled"/> -->
            <Frame x:Name="navigationViewContentFrame">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                    <!-- HEADER -->
                    <Border Grid.Row="0" Background="{ThemeResource SystemControlAcrylicWindowBrush}" Padding="16">
                        <StackPanel>
                            <Image Height="256" Source="/Assets/.a.i. generated/Copilot/Copilot_20260315_191513.png" />
                            <!--<Image Height="256" Source="/Assets/.a.i. generated/Copilot/Copilot_20260315_191519.png" Visibility="Collapsed"/>
                            <TextBlock Text="Vanara – The Friendly Interop Beast" FontSize="28" FontWeight="Bold"/>
                            <TextBlock Text="Bringing WinUI 3 and Win32 together since forever." Opacity="0.7"/>-->
                        </StackPanel>
                    </Border>

                    <!-- TABVIEW -->
                    <TabView x:Name="MainTabs" Grid.Row="1" IsAddTabButtonVisible="False" Visibility="Collapsed">
                        <!--<TabViewItem Header="Overview"/>
                            <TabViewItem Header="Packages"/>
                            <TabViewItem Header="Interop"/>
                            <TabViewItem Header="Shell"/>
                            <TabViewItem Header="Windowing"/>
                            <TabViewItem Header="Composition"/>-->
                    </TabView>

                    <!-- RIBBON (optional) -->
                    <CommandBar x:Name="RibbonBar" Grid.Row="2" DefaultLabelPosition="Right">
                        <AppBarButton Icon="Refresh" Label="Reload"/>
                        <AppBarButton Icon="Copy" Label="Copy Code"/>
                        <AppBarButton Icon="Help" Label="Docs"/>
                    </CommandBar>

                    <!-- CONTENT -->
                    <Frame x:Name="ContentFrame" Grid.Row="3" >
                        <!--<Image Source="Assets/octocat.png" Width="64" Height="64"/>
                        <Image Source="ms-appx:///Assets/octocat.svg"/>-->
                    </Frame>
                </Grid>

