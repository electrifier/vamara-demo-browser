<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="vamara_demo_browser.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:vamara_demo_browser"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="vamara demo browser">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>

        <NavigationView x:Name="navigationView">
            <NavigationView.MenuItems>
                <NavigationViewItem Icon="World" Content="Home" Tag="Wellcome Home" />
                <NavigationViewItem Icon="Save" Content="Windows Forms" Tag="Windows Forms Controls" />
                <NavigationViewItem Icon="ProtectedDocument" Content="Docs" Tag="Documentation" />
                <NavigationViewItem Icon="Calendar" Content="History" Tag="History" />
                <NavigationViewItem Icon="Upload"  Content="App app (use drag and drop, or add manually, or grab folder of open explorer window)" Tag="submit a bug..." />
                <NavigationViewItem Icon="Download" Content="Download" Tag="suggest a feature..." />
                <NavigationViewItem Icon="Download" Content="Download from NuGet" Tag="Download packages from NGet" />
            </NavigationView.MenuItems>
            <Frame x:Name="contentFrame">
                <Border Background="LightGray" Margin="20" CornerRadius="10">
                    <TextBlock HorizontalAlignment="Center" 
                               VerticalAlignment="Center" 
                               Text="Welcome to the Vanara demo browser! TODOs: Version: "/>
                </Border>
                <!-- The contentFrame is well known as the Home screen -->
                <!-- -->
                <!-- insert paste here -->
            </Frame>
        </NavigationView>

    </Grid>
</Window>
