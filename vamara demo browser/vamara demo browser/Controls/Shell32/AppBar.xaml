<UserControl
    x:Class="vamara_demo_browser.Controls.Shell32.AppBarT"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:vamara_demo_browser.Controls.Shell32"
    xmlns:models=models="using:vamara_demo_browser.Models" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    d:DataContext="{d:DesignInstance Type=models1:AppBarT}">

    <Grid Background="{ThemeResource LayerFillColorDefaultBrush}"
          Height="48">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <!-- Navigation -->
            <ColumnDefinition Width="*"/>
            <!-- Breadcrumb -->
            <ColumnDefinition Width="Auto"/>
            <!-- Actions -->
        </Grid.ColumnDefinitions>

        <!-- Navigation Buttons -->
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="4"
                    Margin="8,0">
            <Button x:Name="BackButton"
                    Style="{StaticResource NavigationBackButtonStyle}"
                    ToolTipService.ToolTip="Zurück"/>
            <Button x:Name="ForwardButton"
                    Style="{StaticResource NavigationForwardButtonStyle}"
                    ToolTipService.ToolTip="Vorwärts"/>
            <Button x:Name="UpButton"
                    Icon="Up"
                    ToolTipService.ToolTip="Eine Ebene höher"/>
        </StackPanel>

        <!-- Breadcrumb -->
        <local:Breadcrumb x:Name="BreadcrumbControl"
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          Margin="12,0"/>

        <!-- Action Buttons -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="4"
                    Margin="8,0">
            <Button x:Name="RefreshButton"
                    Icon="Refresh"
                    ToolTipService.ToolTip="Aktualisieren"/>
            <Button x:Name="NewFolderButton"
                    Icon="Add"
                    ToolTipService.ToolTip="Neuer Ordner"/>
            <Button x:Name="PropertiesButton"
                    Icon="Info"
                    ToolTipService.ToolTip="Eigenschaften"/>
        </StackPanel>

    </Grid>
</UserControl>












