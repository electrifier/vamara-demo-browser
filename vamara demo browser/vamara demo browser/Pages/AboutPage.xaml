<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="vamara_demo_browser.Pages.AboutPage"
    xmlns:local="using:vamara_demo_browser.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    mc:Ignorable="d">

    <Grid Padding="32" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="24">

        <!-- Header -->
        <StackPanel>
            <TextBlock Text="Vanara Demo Browser"
                       Style="{StaticResource TitleLargeTextBlockStyle}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Powered by Vanara todo: Version WinUI todo: Version"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Opacity="0.75"/>
        </StackPanel>

        <!-- App Info Card -->
        <Grid Grid.Row="1">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12"
                    Padding="20"
                    Shadow="{ThemeResource ShadowElevation2}">
                <StackPanel Spacing="8">
                    <TextBlock Text="App-Informationen"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <!--<SymbolIcon Symbol="Info"/>
                        <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                   Style="{StaticResource BodyTextBlockStyle}"/>-->
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <!--<SymbolIcon Symbol="Calendar"/>
                        <TextBlock Text="{x:Bind ViewModel.BuildInfo, Mode=OneWay}"
                                   Style="{StaticResource BodyTextBlockStyle}"/>-->
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <SymbolIcon Symbol="Link"/>
                        <HyperlinkButton Content="GitHub Repository"
                                         NavigateUri="https://github.com/electrifier/vamara-demo-browser"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Vanara Assemblies -->
        <Grid Grid.Row="2">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12"
                    Padding="20"
                    Shadow="{ThemeResource ShadowElevation2}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Vanara Bibliotheken"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <!--<ItemsRepeater ItemsSource="{x:Bind ViewModel.VanaraAssemblies, Mode=OneWay}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:VanaraAssemblyInfo">
                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4">
                                    <SymbolIcon Symbol="Library"/>
                                    <TextBlock Text="{x:Bind Name}" Width="240"/>
                                    <TextBlock Text="{x:Bind Version}" Opacity="0.7"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>-->
                </StackPanel>
            </Border>
        </Grid>

        <!-- Vanara Meditation -->
        <Grid Grid.Row="3">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12"
                    Padding="20"
                    Shadow="{ThemeResource ShadowElevation2}">
                <StackPanel>
                    <TextBlock Text="Vanara Meditation"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               Margin="0,0,0,8"/>
                    <!--<TextBlock Text="{x:Bind ViewModel.MeditationText, Mode=OneWay}"
                               Style="{StaticResource BodyItalicTextBlockStyle}"
                               Opacity="0.85"
                               TextWrapping="Wrap"/>-->
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Page>
