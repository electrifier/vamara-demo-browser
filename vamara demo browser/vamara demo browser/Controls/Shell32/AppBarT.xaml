<UserControl x:Class="vamara_demo_browser.Controls.Shell32.AppBarT"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:models="using:vamara_demo_browser.Models" d:DataContext="{d:DesignInstance Type=models:AppBarTViewModel}"
             mc:Ignorable="d">
<!-- TODO: Set design context to correct model! -->
	<Grid Background="{ThemeResource LayerFillColorDefaultBrush}" Height="48">
		<Grid.ColumnDefinitions>
            <ColumnDefinition Width="128"/>
            <ColumnDefinition Width="128"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

		<!-- Navigation Buttons -->
        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <Button x:Name="BackButton" Style="{StaticResource AccentButtonStyle}" ToolTipService.ToolTip="NavigateBack" />
            <Button x:Name="ForwardButton" Style="{StaticResource AccentButtonStyle}" ToolTipService.ToolTip="NavigateForward" />
            <Button x:Name="UpButton" Style="{StaticResource AccentButtonStyle}" ToolTipService.ToolTip="NavigateUp" />
        </StackPanel>

		<!-- Breadcrumb -->
		<!--<local:Breadcrumb x:Name="BreadcrumbControl" Grid.Column="1" Margin="12,0" VerticalAlignment="Center" />-->

		<!-- Action Buttons -->
		<StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="4"
                    Margin="8,0">
			<Button x:Name="RefreshButton"
                    ToolTipService.ToolTip="Aktualisieren"/>
			<Button x:Name="NewFolderButton"
                    ToolTipService.ToolTip="Neuer Ordner"/>
			<Button x:Name="PropertiesButton"
                    ToolTipService.ToolTip="Eigenschaften"/>
		</StackPanel>
	</Grid>
</UserControl>
